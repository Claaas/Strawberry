@page "/Dashboard"
@rendermode InteractiveServer
@implements IDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject EventService EventService
@inject WeighingService WeighingService
@inject BalanceService BalanceService
@inject TranslationService Translation
@inject UserLanguageService Lang

<PageTitle>@T("Dashboard.Title") &ndash; @T("AppName")</PageTitle>

<div class="max-w-[1400px] mx-auto px-4 py-5 sm:px-6 sm:py-6 lg:px-10 lg:py-8">
    <header class="flex items-start justify-between gap-4 mb-6 flex-wrap">
        <div>
            <h1 class="text-2xl font-bold text-zinc-900 tracking-tight leading-tight">@T("Dashboard.Title")</h1>
            <p class="text-sm text-zinc-500 mt-1">@T("Dashboard.Subtitle")</p>
        </div>
    </header>

    @if (_loading)
    {
        <div class="spinner"></div>
    }
    else
    {
        @if (_activeEvent != null)
        {
            <div class="flex items-center gap-2.5 bg-white border border-zinc-200 border-l-[3px] border-l-red-700 rounded text-sm font-medium mb-5 px-3.5 py-2.5 text-zinc-900">
                <div class="w-[7px] h-[7px] rounded-full bg-red-700 flex-shrink-0 event-pulse"></div>
                <span>@T("Dashboard.ActiveEvent", _activeEvent.Name, _activeEvent.PricePerKg.ToString("0.00"))</span>
            </div>
        }

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5 mb-6">
            <div class="bg-white rounded-lg border border-zinc-200 shadow-sm px-5 py-[1.125rem] flex flex-col gap-1 border-l-[3px] border-l-green-700">
                <div class="text-[0.6875rem] font-bold text-zinc-500 uppercase tracking-widest">@T("Dashboard.StatContainers")</div>
                <div class="text-[1.75rem] font-extrabold text-zinc-900 leading-tight tracking-tight">@_containerCount</div>
                <div class="text-xs text-zinc-500 mt-0.5">@T("Dashboard.StatContainersSub")</div>
            </div>
            <div class="bg-white rounded-lg border border-zinc-200 shadow-sm px-5 py-[1.125rem] flex flex-col gap-1 border-l-[3px] border-l-blue-700">
                <div class="text-[0.6875rem] font-bold text-zinc-500 uppercase tracking-widest">@T("Dashboard.StatTotalWeight")</div>
                <div class="text-[1.75rem] font-extrabold text-zinc-900 leading-tight tracking-tight">@_totalWeight.ToString("F1") kg</div>
                <div class="text-xs text-zinc-500 mt-0.5">@T("Dashboard.StatTotalWeightSub")</div>
            </div>
        </div>

        <div class="flex flex-col gap-4">
            <div class="bg-white rounded-lg border border-zinc-200 shadow-sm p-5">
                <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-zinc-200">
                    <h2 class="text-[0.9375rem] font-bold text-zinc-900 tracking-tight">@T("Dashboard.CreateEvent")</h2>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Dashboard.EventName")</label>
                            <input class="w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors" @bind="_newEventName"
                                   placeholder="@T("Dashboard.EventNamePlaceholder")" />
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Dashboard.EventPricePerKg")</label>
                            <input class="w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors" type="number" step="0.01" min="0.01" @bind="_pricePerKg" />
                        </div>
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Dashboard.EventDescription")</label>
                        <input class="w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors" @bind="_newEventDescription"
                               placeholder="@T("Dashboard.EventDescriptionPlaceholder")" />
                    </div>
                    @if (!string.IsNullOrEmpty(_eventMsg))
                    {
                        <div class="px-3.5 py-2.5 rounded text-sm font-medium border bg-green-50 text-green-700 border-green-300">@_eventMsg</div>
                    }
                    <button class="inline-flex items-center justify-center px-4 py-2 rounded border-[1.5px] border-red-700 bg-red-700 text-white text-sm font-semibold min-h-9 cursor-pointer transition-colors hover:bg-red-800 disabled:opacity-45" @onclick="CreateEventAsync">
                        @T("Dashboard.CreateEventButton")
                    </button>
                </div>
            </div>

            @if (_allEvents.Count > 0)
            {
                <div class="bg-white rounded-lg border border-zinc-200 shadow-sm p-5">
                    <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-zinc-200">
                        <h2 class="text-[0.9375rem] font-bold text-zinc-900 tracking-tight">@T("Dashboard.AllEvents")</h2>
                    </div>

                    @if (_editingEvent != null)
                    {
                        <div class="bg-zinc-50 border-[1.5px] border-red-700 rounded-lg p-5 mb-4 flex flex-col gap-4">
                            <h3 class="text-sm font-bold text-zinc-900">@T("Dashboard.EditEvent")</h3>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Dashboard.EventName")</label>
                                    <input class="w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors" @bind="_editName" />
                                </div>
                                <div class="flex flex-col gap-1.5">
                                    <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Dashboard.EventPricePerKg")</label>
                                    <input class="w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors" type="number" step="0.01" min="0.01" @bind="_editPrice" />
                                </div>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Dashboard.EventDescription")</label>
                                <input class="w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors" @bind="_editDescription" />
                            </div>
                            <div class="flex gap-2 flex-wrap">
                                <button class="inline-flex items-center justify-center px-4 py-2 rounded border-[1.5px] border-red-700 bg-red-700 text-white text-sm font-semibold min-h-9 cursor-pointer transition-colors hover:bg-red-800" @onclick="SaveEditAsync">@T("Dashboard.SaveEvent")</button>
                                <button class="inline-flex items-center justify-center px-4 py-2 rounded border-[1.5px] border-zinc-200 bg-transparent text-zinc-500 text-sm font-semibold min-h-9 cursor-pointer transition-colors hover:bg-zinc-50 hover:text-zinc-900" @onclick="() => _editingEvent = null">@T("Dashboard.Cancel")</button>
                            </div>
                        </div>
                    }

                    <div class="flex flex-col divide-y divide-zinc-100 md:hidden">
                        @foreach (var evt in _allEvents)
                        {
                            <div class="py-3 px-1 flex flex-col gap-2">
                                <div class="flex items-start justify-between gap-2">
                                    <div>
                                        <p class="text-sm font-semibold text-zinc-900">@evt.Name</p>
                                        <p class="text-xs text-zinc-400 mt-0.5">@evt.Date.ToLocalTime().ToString("dd MMM yyyy") &middot; &euro;@evt.PricePerKg.ToString("0.00")/kg</p>
                                    </div>
                                    @if (evt.IsActive)
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-green-50 text-green-700 border-green-300 shrink-0">@T("Dashboard.EventActive")</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-zinc-50 text-zinc-500 border-zinc-200 shrink-0">@T("Dashboard.EventClosed")</span>
                                    }
                                </div>
                                <div class="flex gap-1.5 flex-wrap">
                                    @if (!evt.IsActive)
                                    {
                                        <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-zinc-200 bg-white text-zinc-900 text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-zinc-50" @onclick="() => ActivateEventAsync(evt.Id)">@T("Dashboard.ActivateEvent")</button>
                                    }
                                    else
                                    {
                                        <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-zinc-200 bg-transparent text-zinc-500 text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-zinc-50" @onclick="() => CloseEventAsync(evt.Id)">@T("Dashboard.CloseEvent")</button>
                                    }
                                    <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-red-700 bg-transparent text-red-700 text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-red-50" @onclick="() => StartEdit(evt)">@T("Dashboard.EditEvent")</button>
                                    <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-red-800 bg-red-800 text-white text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-red-900" @onclick="() => ConfirmDeleteEvent(evt.Id)">@T("Dashboard.DeleteEvent")</button>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="hidden md:block overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="bg-zinc-50 text-xs font-semibold text-zinc-500 uppercase tracking-wide">
                                <tr>
                                    <th class="px-4 py-3 text-left">@T("Dashboard.ColEventName")</th>
                                    <th class="px-4 py-3 text-left">@T("Dashboard.ColEventDate")</th>
                                    <th class="px-4 py-3 text-left">@T("Dashboard.ColEventPrice")</th>
                                    <th class="px-4 py-3 text-left">@T("Dashboard.ColEventStatus")</th>
                                    <th class="px-4 py-3"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-zinc-100">
                                @foreach (var evt in _allEvents)
                                {
                                    <tr class="hover:bg-zinc-50 transition-colors">
                                        <td class="px-4 py-3 font-medium text-zinc-900">@evt.Name</td>
                                        <td class="px-4 py-3 text-zinc-600">@evt.Date.ToLocalTime().ToString("dd MMM yyyy")</td>
                                        <td class="px-4 py-3 font-mono text-zinc-700">&euro; @evt.PricePerKg.ToString("0.00")/kg</td>
                                        <td class="px-4 py-3">
                                            @if (evt.IsActive)
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-green-50 text-green-700 border-green-300">@T("Dashboard.EventActive")</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-zinc-50 text-zinc-500 border-zinc-200">@T("Dashboard.EventClosed")</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 text-right">
                                            <div class="flex gap-1.5 justify-end flex-wrap">
                                                @if (!evt.IsActive)
                                                {
                                                    <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-zinc-200 bg-white text-zinc-900 text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-zinc-50 hover:border-zinc-400" @onclick="() => ActivateEventAsync(evt.Id)">@T("Dashboard.ActivateEvent")</button>
                                                }
                                                else
                                                {
                                                    <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-zinc-200 bg-transparent text-zinc-500 text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-zinc-50 hover:text-zinc-900" @onclick="() => CloseEventAsync(evt.Id)">@T("Dashboard.CloseEvent")</button>
                                                }
                                                <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-red-700 bg-transparent text-red-700 text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-red-50" @onclick="() => StartEdit(evt)">@T("Dashboard.EditEvent")</button>
                                                <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-red-800 bg-red-800 text-white text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-red-900" @onclick="() => ConfirmDeleteEvent(evt.Id)">@T("Dashboard.DeleteEvent")</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (_activeEvent != null && _balanceList.Count > 0)
            {
                <div class="bg-white rounded-lg border border-zinc-200 shadow-sm p-5">
                    <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-zinc-200">
                        <h2 class="text-[0.9375rem] font-bold text-zinc-900 tracking-tight">@T("Dashboard.ParticipantsBalance")</h2>
                    </div>
                    <div class="flex flex-col divide-y divide-zinc-100 md:hidden">
                        @foreach (var (user, balance) in _balanceList)
                        {
                            <div class="py-3 px-1 flex items-center justify-between gap-2">
                                <div>
                                    <p class="text-sm font-medium text-zinc-900">@user.FirstName @user.LastName</p>
                                    <p class="text-xs text-zinc-400 font-mono mt-0.5">@user.UserName</p>
                                </div>
                                <span class="font-mono font-semibold text-zinc-900">&euro; @balance.ToString("0.00")</span>
                            </div>
                        }
                    </div>

                    <div class="hidden md:block overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="bg-zinc-50 text-xs font-semibold text-zinc-500 uppercase tracking-wide">
                                <tr>
                                    <th class="px-4 py-3 text-left">@T("Dashboard.ColName")</th>
                                    <th class="px-4 py-3 text-left">@T("Dashboard.ColUsername")</th>
                                    <th class="px-4 py-3 text-right">@T("Dashboard.ColBalance")</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-zinc-100">
                                @foreach (var (user, balance) in _balanceList)
                                {
                                    <tr class="hover:bg-zinc-50 transition-colors">
                                        <td class="px-4 py-3 text-zinc-900">@user.FirstName @user.LastName</td>
                                        <td class="px-4 py-3 font-mono text-zinc-600">@user.UserName</td>
                                        <td class="px-4 py-3 text-right font-mono font-semibold text-zinc-900">&euro; @balance.ToString("0.00")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_confirmDeleteEventId != null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm p-4">
        <div class="bg-white rounded-xl shadow-xl max-w-sm w-full p-6 flex flex-col gap-4">
            <h3 class="text-base font-bold text-zinc-900">@T("Dashboard.ConfirmDeleteEventTitle")</h3>
            <p class="text-sm text-zinc-600">@T("Dashboard.ConfirmDeleteEventText")</p>
            <div class="flex gap-2 justify-end">
                <button class="inline-flex items-center justify-center px-4 py-2 rounded border-[1.5px] border-zinc-200 bg-white text-zinc-700 text-sm font-semibold cursor-pointer hover:bg-zinc-50" @onclick="() => _confirmDeleteEventId = null">@T("Dashboard.Cancel")</button>
                <button class="inline-flex items-center justify-center px-4 py-2 rounded border-[1.5px] border-red-800 bg-red-800 text-white text-sm font-semibold cursor-pointer hover:bg-red-900" @onclick="ExecuteDeleteEventAsync">@T("Dashboard.DeleteEvent")</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int? _confirmDeleteEventId;
    private Event? _activeEvent;
    private List<Event> _allEvents = new();

    private string _newEventName = string.Empty;
    private string _newEventDescription = string.Empty;
    private decimal _pricePerKg = 1.50m;
    private string _eventMsg = string.Empty;

    private Event? _editingEvent;
    private string _editName = string.Empty;
    private string _editDescription = string.Empty;
    private decimal _editPrice;

    private List<(AppUser User, decimal Balance)> _balanceList = new();
    private int _containerCount;
    private decimal _totalWeight;

    private string T(string key, params object[] args) => Translation.T(Lang.Language, key, args);
    private Func<Task>? _onChangeSub;

    protected override void OnInitialized()
    {
        _onChangeSub = () => InvokeAsync(StateHasChanged);
        Lang.OnChange += _onChangeSub;
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _activeEvent = await EventService.GetActiveEventAsync();
        _allEvents = await EventService.GetAllEventsAsync();
        if (_activeEvent != null)
        {
            var containers = await EventService.GetContainersForEventAsync(_activeEvent.Id);
            _balanceList = await BalanceService.GetAllBalancesAsync(_activeEvent.Id);
            _containerCount = containers.Count;
            _totalWeight = await WeighingService.GetTotalWeightAsync(_activeEvent.Id);
        }
        _loading = false;
    }

    private async Task CreateEventAsync()
    {
        if (string.IsNullOrWhiteSpace(_newEventName)) return;
        await EventService.CreateEventAsync(_newEventName, _newEventDescription, _pricePerKg);
        _eventMsg = T("Dashboard.EventCreated", _newEventName);
        _newEventName = string.Empty;
        _newEventDescription = string.Empty;
        await LoadAsync();
    }

    private void StartEdit(Event evt)
    {
        _editingEvent = evt;
        _editName = evt.Name;
        _editDescription = evt.Description;
        _editPrice = evt.PricePerKg;
    }

    private async Task SaveEditAsync()
    {
        if (_editingEvent == null) return;
        await EventService.UpdateEventAsync(_editingEvent.Id, _editName, _editDescription, _editPrice);
        _editingEvent = null;
        await LoadAsync();
    }

    private void ConfirmDeleteEvent(int id) => _confirmDeleteEventId = id;

    private async Task ExecuteDeleteEventAsync()
    {
        if (_confirmDeleteEventId == null) return;
        var id = _confirmDeleteEventId.Value;
        _confirmDeleteEventId = null;
        await EventService.DeleteEventAsync(id);
        await LoadAsync();
    }

    private async Task ActivateEventAsync(int id)
    {
        await EventService.SetEventActiveAsync(id, true);
        await LoadAsync();
    }

    private async Task CloseEventAsync(int id)
    {
        await EventService.SetEventActiveAsync(id, false);
        await LoadAsync();
    }

    public void Dispose()
    {
        if (_onChangeSub != null) Lang.OnChange -= _onChangeSub;
    }
}
