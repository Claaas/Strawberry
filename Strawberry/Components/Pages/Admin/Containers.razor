@page "/Admin/Containers"
@rendermode InteractiveServer
@using Strawberry.Components.Layout
@implements IDisposable
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject EventService EventService
@inject QrCodeService QrCodeService
@inject TranslationService Translation
@inject UserLanguageService Lang

<PageTitle>@T("Containers.Title") &ndash; @T("AppName")</PageTitle>

<div class="max-w-[1400px] mx-auto px-4 py-5 sm:px-6 sm:py-6 lg:px-10 lg:py-8">
    <header class="flex items-start justify-between gap-4 mb-6 flex-wrap">
        <div>
            <h1 class="text-2xl font-bold text-zinc-900 tracking-tight leading-tight">@T("Containers.Title")</h1>
            <p class="text-sm text-zinc-500 mt-1">@T("Containers.Subtitle")</p>
        </div>
    </header>

    @if (!_loading && _allEvents.Count > 0)
    {
        <div class="bg-white rounded-lg border border-zinc-200 shadow-sm mb-4 p-4">
            <div class="flex items-center gap-4 flex-wrap">
                <label class="text-[0.8125rem] font-semibold text-zinc-900 whitespace-nowrap">@T("Containers.SelectEvent")</label>
                <select class="max-w-xs w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors form-select" value="@_selectedEventId" @onchange="OnEventChangedAsync">
                    @foreach (var evt in _allEvents)
                    {
                        <option value="@evt.Id">@evt.Name @(evt.IsActive ? "(*)" : "")</option>
                    }
                </select>
            </div>
        </div>
    }

    @if (_loading)
    {
        <div class="spinner"></div>
    }
    else if (_activeEvent == null)
    {
        <div class="px-3.5 py-2.5 rounded text-sm font-medium border bg-red-50 text-red-800 border-red-300">@T("Containers.NoActiveEvent")</div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-[340px_1fr] xl:grid-cols-[380px_1fr] gap-5 items-start">
            <div class="flex flex-col gap-4">
                <div class="bg-white rounded-lg border border-zinc-200 shadow-sm p-5">
                    <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-zinc-200">
                        <h2 class="text-[0.9375rem] font-bold text-zinc-900 tracking-tight">@T("Containers.AddContainer")</h2>
                    </div>
                    <div class="flex flex-col gap-4">
                        <div class="flex border-[1.5px] border-zinc-200 rounded overflow-hidden bg-zinc-50">
                            <button class="flex-1 py-2 px-3.5 border-none text-[0.8125rem] font-semibold cursor-pointer transition-colors whitespace-nowrap @(_mode == "generate" ? "bg-red-700 text-white" : "bg-transparent text-zinc-500 hover:bg-white hover:text-zinc-900")"
                                    @onclick='() => _mode = "generate"'>
                                @T("Containers.ModeGenerate")
                            </button>
                            <button class="flex-1 py-2 px-3.5 border-none text-[0.8125rem] font-semibold cursor-pointer transition-colors whitespace-nowrap @(_mode == "custom" ? "bg-red-700 text-white" : "bg-transparent text-zinc-500 hover:bg-white hover:text-zinc-900")"
                                    @onclick='() => _mode = "custom"'>
                                @T("Containers.ModeCustom")
                            </button>
                        </div>

                        @if (_mode == "generate")
                        {
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Containers.GenerateCount")</label>
                                <input class="w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors" type="number" min="1" max="50" @bind="_generateCount" />
                            </div>
                            <button class="inline-flex items-center justify-center px-4 py-2 rounded border-[1.5px] border-red-700 bg-red-700 text-white text-sm font-semibold min-h-9 cursor-pointer transition-colors hover:bg-red-800 disabled:opacity-45" @onclick="GenerateContainersAsync">
                                @T("Containers.GenerateButton")
                            </button>
                        }
                        else
                        {
                            <div class="px-3.5 py-2.5 rounded text-sm font-medium border bg-blue-50 text-blue-700 border-blue-200">@T("Containers.CustomHint")</div>
                            <div class="flex flex-col gap-1.5">
                                <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Containers.CustomCode")</label>
                                <div class="flex gap-2">
                                    <input class="flex-1 px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors font-mono uppercase tracking-widest"
                                           @bind="_customCode"
                                           @bind:event="oninput"
                                           maxlength="6"
                                           placeholder="@T("Containers.CustomCodePlaceholder")"
                                           style="text-transform:uppercase; letter-spacing:0.15em;" />
                                    <button class="inline-flex items-center justify-center px-4 py-2 rounded border-[1.5px] border-zinc-200 bg-white text-zinc-900 text-sm font-semibold min-h-9 cursor-pointer transition-colors hover:bg-zinc-50 hover:border-zinc-400" @onclick="RegisterCustomAsync">
                                        @T("Containers.RegisterButton")
                                    </button>
                                </div>
                                <span class="text-xs text-zinc-500">@T("Containers.CustomCodeHint")</span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_addMsg))
                        {
                            <div class="px-3.5 py-2.5 rounded text-sm font-medium border @(_addError ? "bg-red-50 text-red-800 border-red-300" : "bg-green-50 text-green-700 border-green-300")">@_addMsg</div>
                        }

                        @if (_newContainers.Count > 0)
                        {
                            <div class="grid gap-2.5" style="grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));">
                                @foreach (var c in _newContainers)
                                {
                                    <div class="flex flex-col items-center gap-1.5 p-2.5 bg-zinc-50 rounded border border-zinc-200">
                                        <QrCodeDisplay Code="@c.QrCode" />
                                        <span class="font-mono text-xs tracking-wide text-zinc-900">@c.QrCode</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="bg-white rounded-lg border border-zinc-200 shadow-sm p-5">
                    <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-zinc-200">
                        <h2 class="text-[0.9375rem] font-bold text-zinc-900 tracking-tight">@T("Containers.AssignContainer")</h2>
                    </div>
                    <div class="flex flex-col gap-4">
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Containers.SelectContainer")</label>
                            <select class="w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors form-select" @bind="_assignContainerId">
                                <option value="0">@T("Containers.SelectContainerPlaceholder")</option>
                                @foreach (var c in _allContainers.Where(c => c.AssignedUserId == null))
                                {
                                    <option value="@c.Id">@c.QrCode</option>
                                }
                            </select>
                        </div>
                        <div class="flex flex-col gap-1.5">
                            <label class="text-[0.8125rem] font-semibold text-zinc-900">@T("Containers.SelectHarvester")</label>
                            <select class="w-full px-3 py-2 border-[1.5px] border-zinc-200 rounded text-[0.9375rem] bg-white text-zinc-900 min-h-[38px] focus:outline-none focus:border-red-700 focus:ring-2 focus:ring-red-700/10 transition-colors form-select" @bind="_assignUserId">
                                <option value="">@T("Containers.SelectHarvesterPlaceholder")</option>
                                @foreach (var u in _harvesters)
                                {
                                    <option value="@u.Id">@u.FirstName @u.LastName (@u.UserName)</option>
                                }
                            </select>
                        </div>
                        @if (!string.IsNullOrEmpty(_assignMsg))
                        {
                            <div class="px-3.5 py-2.5 rounded text-sm font-medium border @(_assignError ? "bg-red-50 text-red-800 border-red-300" : "bg-green-50 text-green-700 border-green-300")">@_assignMsg</div>
                        }
                        <button class="inline-flex items-center justify-center px-4 py-2 rounded border-[1.5px] border-green-700 bg-green-700 text-white text-sm font-semibold min-h-9 cursor-pointer transition-colors hover:bg-green-800 disabled:opacity-45" @onclick="AssignContainerAsync">
                            @T("Containers.AssignButton")
                        </button>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-lg border border-zinc-200 shadow-sm p-5">
                <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-zinc-200">
                    <h2 class="text-[0.9375rem] font-bold text-zinc-900 tracking-tight">@T("Containers.AllContainers")</h2>
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-zinc-50 text-zinc-500 border-zinc-200">@_allContainers.Count</span>
                </div>
                @if (_allContainers.Count == 0)
                {
                    <p class="text-sm text-zinc-500">@T("Containers.NoContainers")</p>
                }
                else
                {
                    <div class="flex flex-col divide-y divide-zinc-100 md:hidden">
                        @foreach (var c in _allContainers)
                        {
                            <div class="py-3 px-1 flex flex-col gap-2">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="font-mono font-semibold text-zinc-900 text-sm">@c.QrCode</span>
                                    <div class="flex items-center gap-1.5">
                                        @if (c.IsCustomCode)
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-blue-50 text-blue-700 border-blue-200">@T("Containers.TypeCustom")</span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-zinc-50 text-zinc-500 border-zinc-200">@T("Containers.TypeGenerated")</span>
                                        }
                                        @StatusBadge(c.Status)
                                    </div>
                                </div>
                                <div class="flex items-center justify-between">
                                    <span class="text-sm text-zinc-600">
                                        @if (c.AssignedUser != null)
                                        {
                                            @($"{c.AssignedUser.FirstName} {c.AssignedUser.LastName}")
                                        }
                                        else
                                        {
                                            <span class="text-zinc-400">@T("Containers.Unassigned")</span>
                                        }
                                    </span>
                                    <div class="flex gap-1.5">
                                        @if (c.AssignedUserId != null)
                                        {
                                            <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-zinc-200 bg-transparent text-zinc-500 text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-zinc-50" @onclick="() => UnassignAsync(c.Id)">@T("Containers.Unassign")</button>
                                        }
                                        <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-red-800 bg-red-800 text-white text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-red-900" @onclick="() => DeleteContainerAsync(c.Id)">@T("Containers.Delete")</button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="hidden md:block overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="bg-zinc-50 text-xs font-semibold text-zinc-500 uppercase tracking-wide">
                                <tr>
                                    <th class="px-4 py-3 text-left">@T("Containers.ColCode")</th>
                                    <th class="px-4 py-3 text-left">@T("Containers.ColStatus")</th>
                                    <th class="px-4 py-3 text-left">@T("Containers.ColAssignedTo")</th>
                                    <th class="px-4 py-3 text-left">@T("Containers.ColType")</th>
                                    <th class="px-4 py-3"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-zinc-100">
                                @foreach (var c in _allContainers)
                                {
                                    <tr class="hover:bg-zinc-50 transition-colors">
                                        <td class="px-4 py-3 font-mono font-medium text-zinc-900">@c.QrCode</td>
                                        <td class="px-4 py-3">@StatusBadge(c.Status)</td>
                                        <td class="px-4 py-3 text-zinc-700">
                                            @if (c.AssignedUser != null)
                                            {
                                                @($"{c.AssignedUser.FirstName} {c.AssignedUser.LastName}")
                                            }
                                            else
                                            {
                                                <span class="text-zinc-400">&mdash;</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3">
                                            @if (c.IsCustomCode)
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-blue-50 text-blue-700 border-blue-200">@T("Containers.TypeCustom")</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-zinc-50 text-zinc-500 border-zinc-200">@T("Containers.TypeGenerated")</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 text-right">
                                            <div class="flex gap-1.5 justify-end">
                                                @if (c.AssignedUserId != null)
                                                {
                                                    <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-zinc-200 bg-transparent text-zinc-500 text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-zinc-50 hover:text-zinc-900" @onclick="() => UnassignAsync(c.Id)">@T("Containers.Unassign")</button>
                                                }
                                                <button class="inline-flex items-center justify-center px-2.5 py-1 rounded border-[1.5px] border-red-800 bg-red-800 text-white text-xs font-semibold min-h-7 cursor-pointer transition-colors hover:bg-red-900" @onclick="() => DeleteContainerAsync(c.Id)">@T("Containers.Delete")</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private bool _loading = true;
    private Event? _activeEvent;
    private List<Event> _allEvents = new();
    private int _selectedEventId;
    private string _mode = "generate";

    private int _generateCount = 1;
    private string _customCode = string.Empty;
    private string _addMsg = string.Empty;
    private bool _addError;
    private List<Container> _newContainers = new();

    private int _assignContainerId;
    private string _assignUserId = string.Empty;
    private string _assignMsg = string.Empty;
    private bool _assignError;

    private List<Container> _allContainers = new();
    private List<AppUser> _harvesters = new();

    private string T(string key, params object[] args) => Translation.T(Lang.Language, key, args);
    private Func<Task>? _onChangeSub;

    protected override void OnInitialized()
    {
        _onChangeSub = () => InvokeAsync(StateHasChanged);
        Lang.OnChange += _onChangeSub;
    }

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _allEvents = await EventService.GetAllEventsAsync();
        if (_selectedEventId == 0)
        {
            _activeEvent = await EventService.GetActiveEventAsync();
            if (_activeEvent != null) _selectedEventId = _activeEvent.Id;
        }
        else
        {
            _activeEvent = _allEvents.FirstOrDefault(e => e.Id == _selectedEventId);
        }
        if (_activeEvent != null)
        {
            _allContainers = await EventService.GetContainersForEventAsync(_activeEvent.Id);
            _harvesters = await EventService.GetAllHarvestersAsync();
        }
        _loading = false;
    }

    private async Task OnEventChangedAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedEventId = id;
            _newContainers.Clear();
            _addMsg = string.Empty;
            _assignMsg = string.Empty;
            await LoadAsync();
        }
    }

    private async Task GenerateContainersAsync()
    {
        if (_activeEvent == null) return;
        _newContainers.Clear();
        for (int i = 0; i < _generateCount; i++)
        {
            var c = await EventService.CreateContainerAsync(_activeEvent.Id, isCustom: false);
            _newContainers.Add(c);
        }
        _addMsg = T("Containers.GeneratedSuccess", _generateCount);
        _addError = false;
        await LoadAsync();
    }

    private async Task RegisterCustomAsync()
    {
        if (_activeEvent == null) return;

        var code = _customCode.Trim().ToUpperInvariant();
        if (code.Length != 6)
        {
            _addMsg = T("Containers.CustomCodeInvalid");
            _addError = true;
            return;
        }

        var result = await EventService.RegisterCustomContainerAsync(_activeEvent.Id, code);
        if (result == null)
        {
            _addMsg = T("Containers.CustomCodeDuplicate", code);
            _addError = true;
            return;
        }

        _newContainers = new List<Container> { result };
        _customCode = string.Empty;
        _addMsg = T("Containers.CustomRegistered", code);
        _addError = false;
        await LoadAsync();
    }

    private async Task AssignContainerAsync()
    {
        if (_assignContainerId == 0 || string.IsNullOrEmpty(_assignUserId))
        {
            _assignMsg = T("Containers.AssignSelectBoth");
            _assignError = true;
            return;
        }
        var ok = await EventService.AssignContainerAsync(_assignContainerId, _assignUserId);
        _assignMsg = ok
            ? T("Containers.AssignSuccess")
            : T("Containers.AssignFailed");
        _assignError = !ok;
        _assignContainerId = 0;
        _assignUserId = string.Empty;
        await LoadAsync();
    }

    private async Task UnassignAsync(int containerId)
    {
        await EventService.UnassignContainerAsync(containerId);
        await LoadAsync();
    }

    private async Task DeleteContainerAsync(int containerId)
    {
        await EventService.DeleteContainerAsync(containerId);
        await LoadAsync();
    }

    private RenderFragment StatusBadge(ContainerStatus status) => status switch
    {
        ContainerStatus.Available => @<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-zinc-50 text-zinc-500 border-zinc-200">@T("Status.Available")</span>,
        ContainerStatus.InUse     => @<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-blue-50 text-blue-700 border-blue-200">@T("Status.InUse")</span>,
        _                         => @<span class="inline-flex items-center px-2 py-0.5 rounded-full text-[0.6875rem] font-bold uppercase tracking-wide border bg-zinc-50 text-zinc-500 border-zinc-200">@T("Status.Unknown")</span>
    };

    public void Dispose()
    {
        if (_onChangeSub != null) Lang.OnChange -= _onChangeSub;
    }
}
