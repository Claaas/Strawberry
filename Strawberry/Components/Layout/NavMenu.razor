@rendermode InteractiveServer
@implements IDisposable
@inject NavigationManager NavigationManager
@inject TranslationService Translation
@inject UserLanguageService Lang
@inject IJSRuntime JS

<div class="@(_mobileOpen ? "block" : "hidden") fixed inset-0 bg-black/40 z-[999]" @onclick="CloseMobileMenu"></div>

<nav class="fixed top-0 left-0 w-full h-[60px] bg-white z-[1001] shadow-sm border-b border-zinc-200 md:w-[260px] md:h-screen md:border-r md:border-b-0 md:shadow-none"
     role="navigation" aria-label="@T("AppName")">

    <div class="flex items-center justify-between px-4 h-full md:hidden">
        <div class="flex items-center gap-2">
            <svg class="w-[22px] h-[22px] flex-shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 3C12 3 5 8 5 14a7 7 0 0014 0C19 8 12 3 12 3z" fill="#b91c1c" opacity="0.9"/>
                <circle cx="9" cy="12" r="1" fill="#fca5a5"/>
                <circle cx="13" cy="10" r="1" fill="#fca5a5"/>
                <circle cx="15" cy="14" r="1" fill="#fca5a5"/>
                <path d="M12 3 C12 3 11 1.5 9.5 1.5" stroke="#166534" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="text-base font-bold text-zinc-900 tracking-tight">@T("AppName")</span>
        </div>
        <button @onclick="ToggleMobileMenu"
                class="text-zinc-600 focus:outline-none"
                aria-label="@(_mobileOpen ? T("Nav.Close") : T("Nav.Open"))"
                aria-expanded="@_mobileOpen">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                @if (_mobileOpen)
                {
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                }
                else
                {
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                }
            </svg>
        </button>
    </div>

    <div class="absolute top-full left-0 w-full bg-white overflow-hidden transition-all duration-300 border-b border-zinc-100 shadow-lg
                @(_mobileOpen ? "max-h-[calc(100vh-60px)] overflow-y-auto" : "max-h-0")
                md:static md:max-h-none md:overflow-visible md:h-screen md:flex md:flex-col md:shadow-none md:border-b-0">

        <div class="hidden md:flex md:items-center md:gap-2.5 md:px-5 md:h-16 md:border-b md:border-zinc-100 md:flex-shrink-0">
            <svg class="w-[26px] h-[26px] flex-shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 3C12 3 5 8 5 14a7 7 0 0014 0C19 8 12 3 12 3z" fill="#b91c1c" opacity="0.9"/>
                <circle cx="9" cy="12" r="1" fill="#fca5a5"/>
                <circle cx="13" cy="10" r="1" fill="#fca5a5"/>
                <circle cx="15" cy="14" r="1" fill="#fca5a5"/>
                <path d="M12 3 C12 3 11 1.5 9.5 1.5" stroke="#166534" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span class="text-base font-bold text-zinc-900 tracking-tight">@T("AppName")</span>
        </div>

        <div class="flex flex-col flex-1 overflow-y-auto">

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <p class="px-5 pt-5 pb-1.5 text-[0.6875rem] font-semibold text-zinc-400 uppercase tracking-wider">@T("Nav.Section.Admin")</p>
                    <ul class="list-none m-0 p-0" role="menubar">
                        <li role="none">
                            <NavLink class="flex items-center px-5 py-4 text-gray-700 no-underline bg-white font-medium hover:bg-gray-50 hover:text-[#8E3838] transition-colors" href="/Dashboard" Match="NavLinkMatch.All" ActiveClass="nav-link--active" @onclick="CloseMobileMenu" role="menuitem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mr-3" aria-hidden="true">
                                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                                </svg>
                                <span>@T("Nav.Dashboard")</span>
                            </NavLink>
                        </li>
                        <li role="none">
                            <NavLink class="flex items-center px-5 py-4 text-gray-700 no-underline bg-white font-medium hover:bg-gray-50 hover:text-[#8E3838] transition-colors" href="/Admin/Users" Match="NavLinkMatch.All" ActiveClass="bg-red-50 text-[#8E3838] border-l-4 border-[#8E3838] font-semibold" @onclick="CloseMobileMenu" role="menuitem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mr-3" aria-hidden="true">
                                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                                </svg>
                                <span>@T("Nav.Users")</span>
                            </NavLink>
                        </li>
                        <li role="none">
                            <NavLink class="flex items-center px-5 py-4 text-gray-700 no-underline bg-white font-medium hover:bg-gray-50 hover:text-[#8E3838] transition-colors" href="/Admin/Containers" Match="NavLinkMatch.All" ActiveClass="bg-red-50 text-[#8E3838] border-l-4 border-[#8E3838] font-semibold" @onclick="CloseMobileMenu" role="menuitem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mr-3" aria-hidden="true">
                                    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>
                                </svg>
                                <span>@T("Nav.Containers")</span>
                            </NavLink>
                        </li>
                        <li role="none">
                            <NavLink class="flex items-center px-5 py-4 text-gray-700 no-underline bg-white font-medium hover:bg-gray-50 hover:text-[#8E3838] transition-colors" href="/DropOff" Match="NavLinkMatch.All" ActiveClass="bg-red-50 text-[#8E3838] border-l-4 border-[#8E3838] font-semibold" @onclick="CloseMobileMenu" role="menuitem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mr-3" aria-hidden="true">
                                    <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                                </svg>
                                <span>@T("Nav.DropOff")</span>
                            </NavLink>
                        </li>
                        <li role="none">
                            <NavLink class="flex items-center px-5 py-4 text-gray-700 no-underline bg-white font-medium hover:bg-gray-50 hover:text-[#8E3838] transition-colors" href="/Stats" Match="NavLinkMatch.All" ActiveClass="bg-red-50 text-[#8E3838] border-l-4 border-[#8E3838] font-semibold" @onclick="CloseMobileMenu" role="menuitem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mr-3" aria-hidden="true">
                                    <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                                </svg>
                                <span>@T("Nav.Stats")</span>
                            </NavLink>
                        </li>
                        <li role="none">
                            <NavLink class="flex items-center px-5 py-4 text-gray-700 no-underline bg-white font-medium hover:bg-gray-50 hover:text-[#8E3838] transition-colors" href="/Admin/AuditLogs" Match="NavLinkMatch.All" ActiveClass="bg-red-50 text-[#8E3838] border-l-4 border-[#8E3838] font-semibold" @onclick="CloseMobileMenu" role="menuitem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mr-3" aria-hidden="true">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                                </svg>
                                <span>@T("Nav.AuditLogs")</span>
                            </NavLink>
                        </li>
                    </ul>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="DropOff">
                <Authorized>
                    <p class="px-5 pt-5 pb-1.5 text-[0.6875rem] font-semibold text-zinc-400 uppercase tracking-wider">@T("Nav.Section.DropOff")</p>
                    <ul class="list-none m-0 p-0" role="menubar">
                        <li role="none">
                            <NavLink class="flex items-center px-5 py-4 text-gray-700 no-underline bg-white font-medium hover:bg-gray-50 hover:text-[#8E3838] transition-colors" href="/DropOff" Match="NavLinkMatch.All" ActiveClass="bg-red-50 text-[#8E3838] border-l-4 border-[#8E3838] font-semibold" @onclick="CloseMobileMenu" role="menuitem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mr-3" aria-hidden="true">
                                    <path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                                </svg>
                                <span>@T("Nav.DropOff")</span>
                            </NavLink>
                        </li>
                    </ul>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView Roles="Harvester">
                <Authorized>
                    <p class="px-5 pt-5 pb-1.5 text-[0.6875rem] font-semibold text-zinc-400 uppercase tracking-wider">@T("Nav.Section.Harvester")</p>
                    <ul class="list-none m-0 p-0" role="menubar">
                        <li role="none">
                            <NavLink class="flex items-center px-5 py-4 text-gray-700 no-underline bg-white font-medium hover:bg-gray-50 hover:text-[#8E3838] transition-colors" href="/MyContainers" Match="NavLinkMatch.All" ActiveClass="bg-red-50 text-[#8E3838] border-l-4 border-[#8E3838] font-semibold" @onclick="CloseMobileMenu" role="menuitem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mr-3" aria-hidden="true">
                                    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>
                                </svg>
                                <span>@T("Nav.MyContainers")</span>
                            </NavLink>
                        </li>
                        <li role="none">
                            <NavLink class="flex items-center px-5 py-4 text-gray-700 no-underline bg-white font-medium hover:bg-gray-50 hover:text-[#8E3838] transition-colors" href="/Payout" Match="NavLinkMatch.All" ActiveClass="bg-red-50 text-[#8E3838] border-l-4 border-[#8E3838] font-semibold" @onclick="CloseMobileMenu" role="menuitem">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mr-3" aria-hidden="true">
                                    <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                                </svg>
                                <span>@T("Nav.Payout")</span>
                            </NavLink>
                        </li>
                    </ul>
                </Authorized>
            </AuthorizeView>

        </div>

        <div class="mt-auto border-t border-zinc-100 px-4 py-4 flex items-center justify-between gap-3">
            <div class="flex items-center gap-1">
                <button class="@(Lang.Language == "en" ? "border-red-700 bg-red-50 text-red-700" : "border-zinc-200 text-zinc-500 hover:bg-zinc-50 hover:text-zinc-900") border-[1.5px] rounded px-2 py-1 text-[0.6875rem] font-bold tracking-wide cursor-pointer transition-colors"
                        @onclick='async () => await SwitchLanguage("en")'>EN</button>
                <button class="@(Lang.Language == "nl" ? "border-red-700 bg-red-50 text-red-700" : "border-zinc-200 text-zinc-500 hover:bg-zinc-50 hover:text-zinc-900") border-[1.5px] rounded px-2 py-1 text-[0.6875rem] font-bold tracking-wide cursor-pointer transition-colors"
                        @onclick='async () => await SwitchLanguage("nl")'>NL</button>
            </div>
            <form method="post" action="/Account/Logout">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 border-[1.5px] border-zinc-200 rounded bg-transparent text-[0.8125rem] font-semibold text-zinc-500 cursor-pointer transition-colors hover:bg-zinc-50 hover:text-zinc-900 whitespace-nowrap">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    @T("Nav.SignOut")
                </button>
            </form>
        </div>

    </div>
</nav>

@code {
    private bool _mobileOpen = false;
    private bool _langRestored = false;
    private string? currentUrl;
    private Func<Task>? _onChangeSub;

    private string T(string key, params object[] args) => Translation.T(Lang.Language, key, args);

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        _onChangeSub = () => InvokeAsync(StateHasChanged);
        Lang.OnChange += _onChangeSub;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_langRestored)
        {
            _langRestored = true;
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "app_lang");
            if (!string.IsNullOrWhiteSpace(saved) && saved != Lang.Language)
                await Lang.SetLanguageAsync(saved);
        }
    }

    private async Task SwitchLanguage(string lang)
    {
        await Lang.SetLanguageAsync(lang);
        await JS.InvokeVoidAsync("localStorage.setItem", "app_lang", lang);
    }

    private void ToggleMobileMenu() => _mobileOpen = !_mobileOpen;
    private void CloseMobileMenu() => _mobileOpen = false;

    public void Dispose()
    {
        if (_onChangeSub != null)
            Lang.OnChange -= _onChangeSub;
    }
}
